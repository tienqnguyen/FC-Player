rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-all Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for SharedUsername entries
    function isValidSharedUsername(data) {
      return data.keys().hasAll(['id', 'username'])
        && data.id is string && data.id.size() <= 128
        && data.username is string && data.username.size() <= 128
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('avatarSub' in data) || (data.avatarSub is string && data.avatarSub.size() <= 32))
        && (!('sharedBy' in data) || (data.sharedBy is string && data.sharedBy.size() <= 128))
        && (!('createdAt' in data) || data.createdAt is string || data.createdAt is timestamp);
    }

    // Validation for SharedTrack entries
    function isValidSharedTrack(data) {
      return data.keys().hasAll(['id', 'title', 'originalUrl'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 1000
        && data.originalUrl is string && data.originalUrl.size() <= 4096
        && (!('author' in data) || (data.author is string && data.author.size() <= 1000))
        && (!('cover' in data) || (data.cover is string && data.cover.size() <= 4096))
        && (!('duration' in data) || (data.duration is int || data.duration is float || data.duration is number))
        && (!('audioUrl' in data) || (data.audioUrl is string && data.audioUrl.size() <= 4096))
        && (!('sharedBy' in data) || (data.sharedBy is string && data.sharedBy.size() <= 128))
        && (!('sharedAt' in data) || data.sharedAt is string || data.sharedAt is timestamp)
        && (!('likes' in data) || (data.likes is int || data.likes is float || data.likes is number));
    }

    // 1. Match block for shared_usernames
    match /shared_usernames/{usernameId} {
      allow get, list: if true;
      allow create: if isValidId(usernameId) && isValidSharedUsername(incoming());
      allow update: if isValidId(usernameId) && isValidSharedUsername(incoming());
      allow delete: if isValidId(usernameId);
    }

    // 2. Match block for shared_tracks
    match /shared_tracks/{trackId} {
      allow get, list: if true;
      allow create: if isValidId(trackId) && isValidSharedTrack(incoming());
      allow update: if isValidId(trackId) && isValidSharedTrack(incoming());
      allow delete: if isValidId(trackId);
    }
  }
}
